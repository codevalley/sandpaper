{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node .sandpaper/hooks/brain-inject.js",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .sandpaper/hooks/brain-stamp-check.js",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
